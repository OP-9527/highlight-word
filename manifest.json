{
  "action": {
    "default_icon": {
      "16": "img/letter-e-16.png"
    },
    "default_title": "English Word Highlighter"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "css": ["styles.css"],
      "js": [
        "content/00_config_state.js",
        "content/10_dom_context.js",
        "content/20_highlighter.js",
        "content/30_popup_translation.js",
        "content/40_known_words_storage.js",
        "content/50_hover_lifecycle.js",
        "content/60_sidebar.js",
        "content/70_selection.js",
        "content/90_bootstrap.js"
      ],
      "exclude_matches": [
        "*://*.youtube.com/live_chat*",
        "*://*.youtube.com/live_chat_replay*"
      ],
      "matches": ["\u003Call_urls>"]
    },
    {
      "css": ["styles.css"],
      "js": [
        "content/00_config_state.js",
        "content/10_dom_context.js",
        "content/20_highlighter.js",
        "content/30_popup_translation.js",
        "content/40_known_words_storage.js",
        "content/50_hover_lifecycle.js",
        "content/60_sidebar.js",
        "content/70_selection.js",
        "content/90_bootstrap.js"
      ],
      "matches": [
        "*://*.youtube.com/live_chat*",
        "*://*.youtube.com/live_chat_replay*"
      ],
      "all_frames": true
    }
  ],
  "description": "Highlight English words to help learn english. Features word translations, pronunciations, vocabulary management, cross-device sync.",
  "icons": {
    "48": "img/letter-e-48.png"
  },
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://dictionary.cambridge.org/*",
    "https://bing.com/*",
    "https://www.bing.com/*"
  ],
  "manifest_version": 3,
  "name": "English Word Highlighter",
  "permissions": ["storage", "activeTab"],
  "update_url": "https://clients2.google.com/service/update2/crx",
  "version": "1.24",
  "web_accessible_resources": [
    {
      "matches": ["\u003Call_urls>"],
      "resources": ["styles.css", "img/*"]
    }
  ]
}
